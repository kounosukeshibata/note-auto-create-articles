# ============================================================
# NOTE AUTO POST — 環境変数サンプル
# ============================================================
# このファイルをコピーして .env を作成し、実際の値を入力してください。
#   cp .env.example .env
# .env はGitにコミットしないでください (.gitignore で除外済み)
# ============================================================

# ============================================================
# ストレージ設定
# memory : インメモリ（データベース不要、起動が速い。テスト用）
# supabase: Supabase PostgreSQL（本番・ローカル実動確認用）
# ============================================================
STORAGE_TYPE=supabase

# ============================================================
# Supabase データベース接続情報
# Supabase ダッシュボード > Project Settings > Database > Connection string
# "JDBC" タブの URL をそのままコピーしてください
# ============================================================
SUPABASE_DB_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-database-password

# ============================================================
# JWT 認証シークレット
# 32文字以上のランダムな文字列を設定してください
# 例: openssl rand -base64 32
# ============================================================
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# ============================================================
# Amazon アフィリエイト設定
# AMAZON_STUB=true のときはスタブを使用（商品検索なし）
# AMAZON_STUB=false のときは Amazon PA-API を使用
# ============================================================
AMAZON_STUB=true
AMAZON_PARTNER_TAG=your-tracking-id-20
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=

# ============================================================
# note.com 設定
# NOTE_STUB=true のときはスタブを使用（実際には投稿しない）
# NOTE_STUB=false のときは note.com API を使用
# ============================================================
NOTE_STUB=true
NOTE_EMAIL=your-note-email@example.com
NOTE_PASSWORD=your-note-password

# ============================================================
# Vertex AI (Google Cloud) 設定
# VERTEX_AI_STUB=true のときはスタブを使用（AI生成なし）
# VERTEX_AI_STUB=false のときは実際の Gemini/Imagen を使用
# ============================================================
VERTEX_AI_STUB=true
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=asia-northeast1

# ============================================================
# CORS 設定（バックエンド）
# カンマ区切りで許可するオリジンを列挙
# 例: https://your-app.vercel.app,https://your-custom-domain.com
# ============================================================
ALLOWED_ORIGINS=http://localhost:5173
